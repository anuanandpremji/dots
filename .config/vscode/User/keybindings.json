// Place your key bindings in this file to override the defaultsauto[]
[
    /******************************************************************************************************************/
    // Navigate back and forth between editors and views
    {
        "command": "workbench.action.navigateBack",
        "key": "alt+left",
        "when": "editorTextFocus" // Shortcut to navigate back in editor history
    },

    {
        "command": "workbench.action.navigateForward",
        "key": "alt+right",
        "when": "editorTextFocus" // Shortcut to navigate forward in editor history
    },

    /******************************************************************************************************************/
    // Quick Open and Explorer view toggle
    {
        "command": "-workbench.action.quickOpen", // Disabling the default Quick Open shortcut
        "key": "ctrl+e"
    },
    {
        "command": "workbench.view.explorer", // Reassigning "ctrl+e" to open the Explorer view
        "key": "ctrl+e"
    },

    /******************************************************************************************************************/
    // Delete lines in the editor
    {
        "command": "editor.action.deleteLines",
        "key": "alt+delete",
        "when": "textInputFocus && !editorReadonly" // Shortcut to delete lines when text input is focused and editor is not read-only
    },

    /******************************************************************************************************************/
    // Split panes
    {
        "key": "ctrl+alt+v",
        "command": "workbench.action.splitEditorRight",
        "when": "editorTextFocus"
    },
    {
        "key": "ctrl+alt+s",
        "command": "workbench.action.splitEditorDown",
        "when": "editorTextFocus"
    },
    {
        "key": "ctrl+alt+v",
        "command": "workbench.action.terminal.split",
        "when": "terminalFocus"
    },
    {
        "key": "ctrl+alt+s",
        "command": "workbench.action.terminal.splitInActiveWorkspace",
        "when": "terminalFocus"
    },

    /******************************************************************************************************************/
    // Navigate between panes (Ctrl+Alt+Arrow)
    {
        "key": "ctrl+alt+left",
        "command": "workbench.action.focusLeftGroup",
        "when": "editorTextFocus"
    },
    {
        "key": "ctrl+alt+down",
        "command": "workbench.action.focusBelowGroup",
        "when": "editorTextFocus"
    },
    {
        "key": "ctrl+alt+up",
        "command": "workbench.action.focusAboveGroup",
        "when": "editorTextFocus"
    },
    {
        "key": "ctrl+alt+right",
        "command": "workbench.action.focusRightGroup",
        "when": "editorTextFocus"
    },
    {
        "key": "ctrl+alt+left",
        "command": "workbench.action.terminal.focusPreviousPane",
        "when": "terminalFocus"
    },
    {
        "key": "ctrl+alt+down",
        "command": "workbench.action.terminal.focusNextPane",
        "when": "terminalFocus"
    },
    {
        "key": "ctrl+alt+up",
        "command": "workbench.action.terminal.focusPreviousPane",
        "when": "terminalFocus"
    },
    {
        "key": "ctrl+alt+right",
        "command": "workbench.action.terminal.focusNextPane",
        "when": "terminalFocus"
    },

    /******************************************************************************************************************/
    // Resize panes and sidebar (Ctrl+Alt+Shift+Arrow)
    {
        "key": "ctrl+alt+shift+right",
        "command": "workbench.action.increaseViewWidth"
    },
    {
        "key": "ctrl+alt+shift+left",
        "command": "workbench.action.decreaseViewWidth"
    },
    {
        "key": "ctrl+alt+shift+down",
        "command": "workbench.action.increaseViewSize"
    },
    {
        "key": "ctrl+alt+shift+up",
        "command": "workbench.action.decreaseViewSize"
    },

    /******************************************************************************************************************/
    // Move editor groups
    {
        "command": "workbench.action.moveEditorToNextGroup",
        "key": "ctrl+k right" // Shortcut to move the editor to the next group
    },
    {
        "command": "-views.moveViewRight", // Disabling the default shortcut for moving views to the right
        "key": "ctrl+k right",
        "when": "focusedView != ''" // Only applies when a view is focused
    },
    {
        "command": "-workbench.action.moveActiveEditorGroupRight", // Disabling the default shortcut for moving the active editor group to the right
        "key": "ctrl+k right"
    },

    /*----------------------------------------------------------------------------------------------------------------*/
    {
        "command": "workbench.action.moveEditorToPreviousGroup",
        "key": "ctrl+k left" // Shortcut to move the editor to the previous group
    },
    {
        "command": "-views.moveViewLeft", // Disabling the default shortcut for moving views to the left
        "key": "ctrl+k left",
        "when": "focusedView != ''" // Only applies when a view is focused
    },
    {
        "command": "-workbench.action.moveActiveEditorGroupLeft", // Disabling the default shortcut for moving the active editor group to the left
        "key": "ctrl+k left"
    },

    /*----------------------------------------------------------------------------------------------------------------*/
    {
        "command": "-workbench.action.moveActiveEditorGroupUp", // Disabling the default shortcut for moving the active editor group up
        "key": "ctrl+k up"
    },
    {
        "command": "workbench.action.moveEditorToAboveGroup",
        "key": "ctrl+k up" // Shortcut to move the editor to the group above
    },

    /*----------------------------------------------------------------------------------------------------------------*/
    {
        "command": "-workbench.action.moveActiveEditorGroupDown", // Disabling the default shortcut for moving the active editor group down
        "key": "ctrl+k down"
    },
    {
        "command": "workbench.action.moveEditorToBelowGroup",
        "key": "ctrl+k down" // Shortcut to move the editor to the group below
    },

    /******************************************************************************************************************/
    // Toggle terminal and panel and also manage terminal size
    {
        "key": "ctrl+`",
        "command": "workbench.action.togglePanel", // Shortcut to toggle the panel
        "when": "!terminalFocus" // Only when the terminal is not focused
    },
    {
        "key": "ctrl+j",
        "command": "-workbench.action.togglePanel" // Disabling the default shortcut for toggling the panel
    },
    {
        "key": "ctrl+j",
        "command": "workbench.action.terminal.toggleTerminal",
        "when": "terminal.active" // Shortcut to toggle the terminal when it is active
    },
    {
        "key": "ctrl+`",
        "command": "-workbench.action.terminal.toggleTerminal",
        "when": "terminal.active" // Disabling the default terminal toggle shortcut when the terminal is active
    },

    // Maximize and restore the active pane
    {
        "command": "workbench.action.toggleMaximizedPanel",
        "key": "shift+escape",
        "when": "terminalFocus && terminalProcessSupported"
    },
    {
        "command": "workbench.action.toggleEditorWidths",
        "key": "shift+escape",
        "when": "editorTextFocus"
    },
    {
        "key": "shift+enter",
        "command": "workbench.action.terminal.sendSequence",
        "args": {
            "text": "\u001b\r"
        },
        "when": "terminalFocus"
    },
    /******************************************************************************************************************/

]
