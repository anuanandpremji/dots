[alias]
    lg            = log --abbrev-commit             \
                        --decorate=auto             \
                        --date=format:'%Y-%m-%d %a' \
                        --format=format:'%C(yellow)%h%C(reset)  %C(cyan)%ad%C(reset)  %C(green)%<(16,trunc)%an%C(reset)  %C(italic)%>|(1)%s%C(reset) %C(bold 1)%d%C(reset)'

[color]
    ui            = auto

[color "branch"]
    current       = yellow reverse
    local         = yellow
    remote        = green

[color "status"]
    added         = yellow
    changed       = green
    untracked     = cyan

[core]
    editor        = micro
    pager         = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    features = decorations
    hyperlinks = true
    line-numbers = true
    navigate = true
    side-by-side = false

# Use separate file for user info, github token etc
[include]
    path          = config.local

[merge]
    conflictstyle = diff3

