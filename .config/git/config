[alias]
    lg            = log --abbrev-commit             \
                        --decorate=auto             \
                        --date=format:'%Y-%m-%d %a' \
                        --format=format:'%C(yellow)%h%C(reset)  %C(cyan)%ad%C(reset)  %C(green)%<(16,trunc)%an%C(reset)  %C(italic)%>|(1)%s%C(reset) %C(bold 1)%d%C(reset)'

[color]
    ui            = auto

[color "branch"]
    current       = yellow reverse
    local         = yellow
    remote        = green

[color "status"]
    added         = yellow
    changed       = green
    untracked     = cyan

[core]
    editor        = fresh
    pager         = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    features = decorations
    hyperlinks = true
    line-numbers = true
    navigate = true
    side-by-side = false

# Default identity — machine-specific, not tracked. Points to either
# private or work identity depending on what setup_identities.sh configured.
[include]
    path          = config.default

# Directory-specific overrides (always apply regardless of default)
[includeIf "gitdir:~/private/"]
    path          = config.private

[includeIf "gitdir:~/work/"]
    path          = config.work

[merge]
    conflictstyle = diff3

