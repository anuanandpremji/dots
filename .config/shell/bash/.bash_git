#!/bin/bash

#╔═════════════════════════════════════════════════════════════════════════════════════════════════════════════════════╗
#║ Git functions                                                                                                       ║
#╚═════════════════════════════════════════════════════════════════════════════════════════════════════════════════════╝

#╔═════════════════════════════════════════════════════════════════════════════════════════════════════════════════════╗
#║ Overview                                                                                                            ║
#║ --------                                                                                                            ║
#║ _git_web_url() - Convert a git remote URL to an HTTPS web URL (resolves SSH host aliases)                          ║
#║ cdgr()         - cd to the git repository root (outermost superproject)                                            ║
#║ gho()          - Open the remote repository page (GitHub, GitLab, etc.) in a browser                               ║
#║ gr()           - List git remotes; one line per remote, two lines only if fetch and push URLs differ               ║
#║ gl()           - Browse git commits with delta-powered preview                                                      ║
#║ gc()           - Checkout branches, tags, or commits with diff preview and branch management                        ║
#║ ga()           - Stage, unstage, and commit with live status, diff preview, and delta                               ║
#╚═════════════════════════════════════════════════════════════════════════════════════════════════════════════════════╝

# ════════════════════════════════════════════════════════════════════════════════════════════════════════════════════ #

# _git_web_url() - Convert a git remote URL to an HTTPS web URL
# Resolves SSH host aliases (e.g. github-private → github.com) via ssh -G.

# Usage: _git_web_url [remote]   (defaults to "origin")

_git_web_url()
{
    local remote="${1:-origin}"
    local raw_url
    raw_url=$(git config remote."$remote".url 2>/dev/null) || return 1

    # Resolve SSH host aliases (e.g. github-private → github.com)
    local ssh_host
    ssh_host=$(printf '%s' "$raw_url" | sed -n 's|^git@\([^:]*\):.*|\1|p')
    if [ -n "$ssh_host" ]; then
        local real_host
        real_host=$(ssh -G "$ssh_host" 2>/dev/null | awk '/^hostname / {print $2}')
        [ -n "$real_host" ] && raw_url=$(printf '%s' "$raw_url" | sed "s|^git@${ssh_host}:|git@${real_host}:|")
    fi

    printf '%s' "$raw_url" \
        | sed -e "s|^ssh://git@|https://|" \
              -e "s|^git@\([^:]*\):|https://\1/|" \
              -e "s|\.git$||"
}

# ════════════════════════════════════════════════════════════════════════════════════════════════════════════════════ #

# cdgr() - cd to the outermost Git superproject root directory

cdgr()
{
    local gitroot;
    gitroot="$(git rev-parse --show-toplevel)";

    [ -z "$gitroot" ] && return 1;

    while [ -n "$gitroot" ]; do
        cd "$gitroot" || return 1;
        gitroot="$(git rev-parse --show-superproject-working-tree 2>/dev/null)";
    done

    return 0;
}

# ════════════════════════════════════════════════════════════════════════════════════════════════════════════════════ #

# gho() - Open GitHub/GitLab page of a repository from the terminal
# (named gho to avoid colliding with the official GitHub CLI `gh`)

# Usage:
# gho from a non git repo gives you an error message and exits
# gho from a repo opens the current branch on origin (or the default branch if
#   the current branch doesn't exist on origin)
# gho <remote> opens the remote. For eg, gho upstream.

# Dependencies: git, ssh, _git_web_url(), open_command()

gho()
{(
    set -e;
    git remote -v | grep push;
    remote=${1:-origin};
    printf "Using remote %s\n" "$remote";

    URL=$(_git_web_url "$remote");

    if [ -z "$1" ]; then
        branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || true);
        if [ -n "$branch" ] && [ "$branch" != "HEAD" ] \
            && git rev-parse --verify "origin/$branch" >/dev/null 2>&1; then
            case "$URL" in
                *gitlab*) URL="$URL/-/tree/$branch" ;;
                *)        URL="$URL/tree/$branch" ;;
            esac
        fi
    fi

    printf "Opening %s\n" "$URL";
    open_command "$URL" >/dev/null;
)}

# ════════════════════════════════════════════════════════════════════════════════════════════════════════════════════ #

# gr() - List git remotes, aligned in columns.
# Shows one line per remote. If a remote's push URL differs from its fetch URL, shows both.
gr() {
    git remote -v | awk -F'\t' '
        {
            name = $1
            rest = $2
            if (sub(/ \(fetch\)$/, "", rest)) type = "fetch"
            else { sub(/ \(push\)$/, "", rest); type = "push" }
            if (!(name in seen)) { order[++n] = name; seen[name] = 1 }
            if (type == "fetch") fetch[name] = rest
            else                 push[name]  = rest
            if (length(name) > w) w = length(name)
        }
        END {
            for (i = 1; i <= n; i++) {
                name = order[i]
                f = fetch[name]
                p = (name in push) ? push[name] : f
                if (f == p) {
                    printf "%-*s  %s\n", w, name, f
                } else {
                    printf "%-*s  %s  (fetch)\n", w, name, f
                    printf "%-*s  %s  (push)\n",  w, name, p
                }
            }
        }
    '
}

# ════════════════════════════════════════════════════════════════════════════════════════════════════════════════════ #

# gl() - Browse git commits with delta-powered preview
#
# ENTER    - git show (view the commit with full diff)
# CTRL-D   - git diff (between that commit and the working tree)
# CTRL-Y   - copy the commit hash to clipboard
# CTRL-O   - open the commit on GitHub
# CTRL-F   - filter by author
# CTRL-T   - filter by commit message
# ?        - toggle preview window

gl()
{
    if ! git rev-parse --git-dir > /dev/null 2>&1; then printf "Not inside a Git repository.\n"; return 1; fi

    local delta_cmd="delta \
        --paging=never \
        --width=\$FZF_PREVIEW_COLUMNS \
        --line-numbers \
        --syntax-theme=ansi \
        --minus-style='normal #b06060' \
        --plus-style='normal #408040' \
        --minus-emph-style='bold #a04040' \
        --plus-emph-style='bold #306030' \
        --line-numbers-minus-style='#b06060' \
        --line-numbers-plus-style='#408040' \
        --hunk-header-style=syntax"

    local preview_cmd="
    [ -n {1} ] || exit 0;
    printf '\e[33;1m%s\e[0m\n' \"\$(git log -1 --format='%h  %ad  %aN' --date=format:'%Y-%m-%d %H:%M' {1})\";
    printf '%s\n\n' \"\$(git log -1 --format='%s%n%n%b' {1})\";
    git --no-pager show --stat --color=always --format='' {1} 2>/dev/null;
    echo;
    git --no-pager show --color=never --format='' {1} 2>/dev/null | $delta_cmd"

    local github_url
    github_url=$(_git_web_url origin)

    local open_cmd="xdg-open"
    [[ "$OSTYPE" == darwin* ]] && open_cmd="open"

    local clip_cmd="xclip -selection clipboard"
    if [[ "$OSTYPE" == darwin* ]]; then clip_cmd="pbcopy"
    elif [[ -n "$WAYLAND_DISPLAY" ]]; then clip_cmd="wl-copy"
    fi

    local -a git_log_opts=(
        --color=always
        --date=format:'%d.%b.%y'
        --format=format:$'%C(yellow)%h%C(reset)\t%C(auto)%d%C(reset)\t%s\t%ad\t%aN'
    )

    local -a fzf_opts=(
        --ansi --no-sort --height=100% --freeze-left=10
        --ghost 'Filter commits on the current branch...'
        --highlight-line
        --style=full
        --header-lines=1
        --preview "$preview_cmd"
        --preview-window 'down:60%:hidden'
        --preview-label=' Commit Details '
        --preview-label-pos=2
        --header-border=line
        --footer " ↵ Show │ ^D Diff │ ^Y Copy Hash │ ^O GitHub │ ^F Author │ ^T Msg │ ? Preview"
        --footer-border=line
        --color 'label:yellow:bold,header:bold'
        --delimiter '│'
        --bind '?:toggle-preview'
        --info-command "printf 'On  \xee\x82\xa0 %s  %s' '$(git branch --show-current 2>/dev/null || echo detached)' \"\$FZF_INFO\""
        --bind 'enter:execute(git show --color=always {1})'
        --bind 'ctrl-d:execute(git diff --color=always {1})'
        --bind "ctrl-y:execute-silent(printf '%s' {1} | $clip_cmd)+change-ghost(Copied commit hash to clipboard)"
        --bind "ctrl-o:execute-silent[sha={1}; $open_cmd \"$github_url/commit/\$sha\" >/dev/null 2>&1 &]"
        --bind 'ctrl-f:change-nth(3)+change-ghost(Author filter — press ctrl-a to reset)'
        --bind 'ctrl-t:change-nth(2)+change-ghost(Message filter — press ctrl-a to reset)'
        --bind 'ctrl-a:change-nth(..)+change-ghost(Filter commits on the current branch...)'
    )

    git log "${git_log_opts[@]}" "$@" \
    | awk -v cols="$(tput cols)" -F'\t' '
        function strip(s,  r) { r=s; gsub(/\033\[[0-9;]*m/,"",r); return r }
        function vlen(s,   r) { r=s; gsub(/\033\[[0-9;]*m/,"",r); gsub(/[\200-\277]/,"",r); return length(r) }
        NR == 1 {
            eff = (cols > 120 ? 120 : cols)
            hash_len = length(strip($1))
            subj_col = eff - hash_len - 27
            if (subj_col < 7) subj_col = 7
            printf "%-*s│ %-*s │ %-10s │ Date\n", hash_len, "Hash", subj_col, "Subject", "Author"
        }
        {
            eff = (cols > 120 ? 120 : cols)
            split($5, n, " "); first = n[1]
            if (length(first) > 10) first = substr(first, 1, 9) "."
            age        = $4
            right      = sprintf("%-10s │ %s", first, age)
            rlen       = 22
            hash_len   = length(strip($1))
            decor_clean = strip($2)
            decor_len  = length(decor_clean)
            base_len   = hash_len + 2 + (decor_len > 0 ? decor_len + 1 : 0)
            available  = eff - base_len - 3 - rlen
            if (available < 10) available = 10
            subj = $3
            truncated = 0
            if (vlen(subj) > available) { subj = substr(subj, 1, available - 2); truncated = 1 }
            left = $1 "\033[2m│\033[0m "
            if (decor_len > 0) left = left $2 " "
            left = left subj
            if (truncated) left = left "\033[2m··\033[0m"
            llen = base_len + vlen(subj) + (truncated ? 2 : 0)
            sep  = " \033[2m│\033[0m "
            pad  = eff - llen - 3 - rlen
            if (pad < 0) pad = 0
            printf "%s%*s%s\033[2m%s\033[0m\n", left, pad, "", sep, right
        }' \
    | fzf "${fzf_opts[@]}"
}

# ════════════════════════════════════════════════════════════════════════════════════════════════════════════════════ #

# gc() - Interactive git checkout for branches, tags, and recent commits
#
# ENTER    - checkout the selected branch, tag, or commit
# CTRL-S   - cycle between Branches / Tags / Recent Commits views
# CTRL-N   - create a new branch from the current HEAD
# CTRL-O   - open the branch, tag, or commit on GitHub
# ALT-X    - delete the selected local branch
# ?        - toggle preview window

gc()
{
    if ! git rev-parse --git-dir > /dev/null 2>&1; then printf "Not inside a Git repository.\n"; return 1; fi

    local branch_cmd="git branch --all | cut -c3- | grep -v HEAD | grep ."
    local tag_cmd="git tag --sort=-creatordate"
    local recent_cmd="git log --oneline -50"

    local delta_cmd="delta \
        --paging=never \
        --width=\$FZF_PREVIEW_COLUMNS \
        --line-numbers \
        --syntax-theme=ansi \
        --minus-style='normal #b06060' \
        --plus-style='normal #408040' \
        --minus-emph-style='bold #a04040' \
        --plus-emph-style='bold #306030' \
        --line-numbers-minus-style='#b06060' \
        --line-numbers-plus-style='#408040' \
        --hunk-header-style=syntax"

    local github_url
    github_url=$(_git_web_url origin)

    local open_cmd="xdg-open"
    [[ "$OSTYPE" == darwin* ]] && open_cmd="open"

    local preview_cmd="
    [ -n {} ] || exit 0;
    ref={1};
    if git rev-parse --verify \"\$ref\" >/dev/null 2>&1; then
        printf '\e[33;1m%s\e[0m\n' \"\$(git log -1 --format='%h  %ad  %an' --date=format:'%Y-%m-%d %a' \"\$ref\")\";
        printf '%s\n\n' \"\$(git log -1 --format='%s%n%n%b' \"\$ref\")\";
        git --no-pager diff --stat --color=always \"\$ref\"~1 \"\$ref\" 2>/dev/null;
        echo;
        git --no-pager diff --color=never \"\$ref\"~1 \"\$ref\" 2>/dev/null | $delta_cmd;
    fi"

    local bind_cycle="ctrl-s:transform:
        if [[ \$FZF_PROMPT =~ Branches ]]; then
            echo 'change-prompt(Tags ▶ )+reload[$tag_cmd]+change-ghost(Filter tags sorted by date...)+refresh-preview';
        elif [[ \$FZF_PROMPT =~ Tags ]]; then
            echo 'change-prompt(Commits ▶ )+reload[$recent_cmd]+change-ghost(Filter last 50 commits on the current branch...)+refresh-preview';
        else
            echo 'change-prompt(Branches ▶ )+reload[$branch_cmd]+change-ghost(Filter branches across all remotes...)+refresh-preview';
        fi"

    # _git_web_url is a shell function not available in fzf subshells,
    # so we inline the SSH alias resolution for the branch-open binding.
    local bind_open="ctrl-o:transform:
        if [[ \$FZF_PROMPT =~ Branches ]]; then
            echo 'execute-silent(
                ref={1};
                remote=origin;
                branch=\$ref;
                tmp=\${ref#remotes/};
                if [[ \$tmp != \$ref ]]; then
                    remote=\${tmp%%/*};
                    branch=\${tmp#*/};
                fi;
                raw=\$(git config remote.\$remote.url 2>/dev/null);
                ssh_host=\$(printf \"%s\" \"\$raw\" | sed -n \"s|^git@\\([^:]*\\):.*|\\1|p\");
                if [ -n \"\$ssh_host\" ]; then
                    real=\$(ssh -G \"\$ssh_host\" 2>/dev/null | awk \"/^hostname / {print \\\$2}\");
                    [ -n \"\$real\" ] && raw=\$(printf \"%s\" \"\$raw\" | sed \"s|^git@\${ssh_host}:|git@\${real}:|\");
                fi;
                url=\$(printf \"%s\" \"\$raw\"
                    | sed \"s/\\.git\$//\"
                    | sed \"s|^ssh://git@|https://|\"
                    | sed \"s|^git@\\([^:]*\\):|https://\\1/|\");
                $open_cmd \"\$url/tree/\$branch\" >/dev/null 2>&1 &
            )';
        elif [[ \$FZF_PROMPT =~ Tags ]]; then
            echo 'execute-silent[
                tag={1};
                $open_cmd \"$github_url/releases/tag/\$tag\" >/dev/null 2>&1 &
            ]';
        else
            echo 'execute-silent[
                sha={1};
                $open_cmd \"$github_url/commit/\$sha\" >/dev/null 2>&1 &
            ]';
        fi"

    local bind_delete="alt-x:transform:
        if [[ \$FZF_PROMPT =~ Branches ]]; then
            echo 'execute(git branch -d {1})+reload[$branch_cmd]+refresh-preview';
        fi"

    local bind_new_branch="ctrl-n:execute(
        printf \"New branch name: \";
        read branch_name;
        if [ -n \"\$branch_name\" ]; then
            git checkout -b \"\$branch_name\";
        fi
    )"

    local -a fzf_opts=(
        --ansi --no-sort --height=100%
        --prompt 'Branches ▶ '
        --ghost 'Filter branches across all remotes...'
        --highlight-line
        --style=full
        --preview "$preview_cmd"
        --preview-window 'down:60%:hidden'
        --preview-label=' Commit Details '
        --preview-label-pos=2
        --header-border=line
        --footer " ↵ Checkout │ ^S Cycle View │ ^N New Branch │ ^O GitHub │ Alt-X Delete │ ? Preview"
        --footer-border=line
        --color 'label:yellow:bold,header:dim'
        --bind '?:toggle-preview'
        --bind "start:bg-transform-header:printf '  On: %s' \"\$(git branch --show-current 2>/dev/null || echo 'detached')\""
        --bind "$bind_cycle"
        --bind "enter:become(git checkout {1})"
        --bind "$bind_open"
        --bind "$bind_delete"
        --bind "$bind_new_branch"
    )

    eval "$branch_cmd" | fzf "${fzf_opts[@]}"
}

# ════════════════════════════════════════════════════════════════════════════════════════════════════════════════════ #

# ga() - Interactive git staging, unstaging, and committing
#
# ENTER  - stage selected file(s), or unstage if viewing staged files
# CTRL-S - switch between Unstaged and Staged views
# CTRL-C - commit staged changes (opens $VISUAL for commit message)
# ALT-E  - open selected file(s) in $EDITOR
# ALT-A  - stage all unstaged files at once
# ?      - toggle preview window

ga()
{
    if ! git rev-parse --git-dir > /dev/null 2>&1; then printf "Not inside a Git repository.\n"; return 1; fi

    local toplevel
    toplevel=$(git rev-parse --show-toplevel)

    local unstaged_cmd="git ls-files --modified --deleted --other --exclude-standard --deduplicate \"$toplevel\""
    local staged_cmd="git diff --cached --name-only"

    if [[ -z "$(eval "$unstaged_cmd")" && -z "$(eval "$staged_cmd")" ]]; then
        printf "Nothing to stage or commit.\n"
        return 0
    fi

    local delta_cmd="delta \
        --paging=never \
        --width=\$FZF_PREVIEW_COLUMNS \
        --line-numbers \
        --syntax-theme=ansi \
        --minus-style='normal #b06060' \
        --plus-style='normal #408040' \
        --minus-emph-style='bold #a04040' \
        --plus-emph-style='bold #306030' \
        --line-numbers-minus-style='#b06060' \
        --line-numbers-plus-style='#408040' \
        --hunk-header-style=syntax"

    local preview_cmd="
    [ -n {} ] || exit 0;
    if [[ {fzf:prompt} =~ Unstaged ]]; then
        if git ls-files --error-unmatch {} >/dev/null 2>&1; then
            git --no-pager diff --color=never -- {} | $delta_cmd;
        else
            git --no-pager diff --color=never --no-index /dev/null -- {} | $delta_cmd;
        fi;
    else
        git --no-pager diff --cached --color=never -- {} | $delta_cmd;
    fi"

    # Dynamic header showing current git status summary
    local status_header_cmd="
    s=\$(git diff --cached --name-only | wc -l | tr -d ' ');
    u=\$(git ls-files --modified --deleted --other --exclude-standard --deduplicate \"$toplevel\" | wc -l | tr -d ' ');
    printf '  Staged: %s  │  Unstaged: %s' \"\$s\" \"\$u\""

    local bind_toggle_mode="ctrl-s:transform:
        if [[ \$FZF_PROMPT =~ Unstaged ]]; then
            echo 'change-prompt(Staged ▶ )+reload($staged_cmd)+change-ghost(Filter files staged for commit...)+refresh-preview';
        else
            echo 'change-prompt(Unstaged ▶ )+reload($unstaged_cmd)+change-ghost(Filter unstaged changes in the working tree...)+refresh-preview';
        fi"

    local bind_enter="enter:execute-silent(
        if [[ {fzf:prompt} =~ Unstaged ]]; then
            git add -- {+};
        else
            git restore --staged -- {+};
        fi)+transform:
        if [[ \$FZF_PROMPT =~ Unstaged ]]; then
            echo 'reload($unstaged_cmd)+refresh-preview';
        else
            echo 'reload($staged_cmd)+refresh-preview';
        fi"

    local bind_commit="ctrl-c:execute(
        if [ -z \"\$(git diff --cached --name-only)\" ]; then
            printf 'Nothing staged to commit. Press Enter to return.\n';
            read;
        else
            git commit;
        fi)+reload($unstaged_cmd)+change-prompt(Unstaged ▶ )+change-ghost(Filter unstaged changes in the working tree...)+refresh-preview"

    local bind_stage_all="alt-a:transform:
        if [[ \$FZF_PROMPT =~ Unstaged ]]; then
            echo 'execute-silent(git add -- {*})+reload($unstaged_cmd)+refresh-preview';
        fi"

    local -a fzf_opts=(
        --multi --no-sort --height=100%
        --prompt 'Unstaged ▶ '
        --ghost 'Filter unstaged changes in the working tree...'
        --highlight-line
        --style=full
        --preview "$preview_cmd"
        --preview-window 'down:60%:hidden'
        --preview-label=' Diff '
        --preview-label-pos=2
        --header-border=line
        --footer " ↵ Stage/Unstage │ ^S Switch View │ ^C Commit │ Alt-A Stage All │ Alt-E Editor │ ? Preview"
        --footer-border=line
        --color 'label:yellow:bold,header:dim'
        --bind '?:toggle-preview'
        --bind "start,focus:bg-transform-header($status_header_cmd)"
        --bind "$bind_toggle_mode"
        --bind "$bind_enter"
        --bind "$bind_commit"
        --bind "$bind_stage_all"
        --bind 'alt-e:execute(${EDITOR:-vim} {+})+refresh-preview'
    )

    eval "$unstaged_cmd" | fzf "${fzf_opts[@]}"
    local rc=$?
    [[ $rc -eq 1 || $rc -eq 130 ]] && return 0
    return $rc
}

# ════════════════════════════════════════════════════════════════════════════════════════════════════════════════════ #

# Dependency check

if ! _has git;   then printf "git: program not found. Install git.\n";     fi
if ! _has delta; then printf "delta: program not found. Install delta.\n"; fi

# ════════════════════════════════════════════════════════════════════════════════════════════════════════════════════ #
