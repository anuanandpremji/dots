{
    "agent": {
        "button": false,
        "enable_feedback": false,
        "favorite_models": [],
        "model_parameters": [],
    },
    "agent_ui_font_size": 16.0,
    "bottom_dock_layout": "full",
    "buffer_font_family": "JetBrainsMonoNL Nerd Font",
    "buffer_font_size": 16.0,
    "buffer_font_weight": 600.0,
    "buffer_line_height": "standard",
    "collaboration_panel": {
        "button": false,
    },
    "cursor_shape": "block",
    "diagnostics": {
        "button": true,
    },
    "disable_ai": true,
    "fast_scroll_sensitivity": 8.0,
    "file_types": {
        "Bash": ["**/.bash_*", "**/.bashprompt_*"],
        "Shell Script": ["**/.zsh_*", "**/.zshprompt_*"],
    },
    "git": {
        "blame": {
            "show_avatar": false,
        },
    },
    "git_panel": {
        "status_style": "icon",
        "tree_view": false,
    },
    "icon_theme": "Zed (Default)",
    "outline_panel": {
        "button": true,
        "default_width": 325.0,
        "dock": "left",
    },
    "project_panel": {
        "bold_folder_labels": true,
        "button": true,
        "drag_and_drop": false,
        "entry_spacing": "standard",
        "folder_icons": true,
    },
    "scroll_sensitivity": 4.0,
    "session": {
        "trust_all_worktrees": true,
    },
    "show_whitespaces": "all",
    "status_bar": {
        "active_language_button": true,
        "cursor_position_button": true,
    },
    "tab_size": 4,
