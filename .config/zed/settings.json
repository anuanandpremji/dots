        "blinking": "on",
        "cursor_shape": "block",
        "default_height": 500,
        "font_weight": 600.0,
    },
    "theme": {
        "dark": "Vitesse Dark Soft",
        "light": "VSCode Light Modern",
        "mode": "system",
    },
    "title_bar": {
        "show_branch_icon": true,
        "show_menus": false,
        "show_sign_in": false,
        "show_user_menu": false,
        "show_user_picture": false,
    },
    "ui_font_family": "SF Mono",
    "ui_font_size": 18.0,
    "ui_font_weight": 600.0,
    "vim_mode": false,
    "window_decorations": "client",
