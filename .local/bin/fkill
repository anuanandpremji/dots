#!/usr/bin/env bash
#
# fkill - Fuzzy find a running process and kill it.
#
# Usage: fkill [signal]   (default signal: 9)

if ! command -v fzf >/dev/null 2>&1; then printf "fkill: fzf not found.\n" >&2; exit 1; fi

local_fzf_opts=(
    -m
    --border-label=" Find and Kill a Process "
    --border-label-pos=2
    --color 'label:yellow:bold'
)

pid=""
if [ "$UID" != "0" ]; then
    pid=$(ps -f -u "$UID" | sed 1d | fzf "${local_fzf_opts[@]}" | awk '{print $2}')
else
    pid=$(ps -ef | sed 1d | fzf "${local_fzf_opts[@]}" | awk '{print $2}')
fi

if [ -n "$pid" ]; then
    printf "%s" "$pid" | xargs kill -"${1:-9}"
fi
