#!/usr/bin/env bash
#
# upgrade — Run system updates across all detected package managers.
#
# ┌─ What runs (each step only if the package manager is installed) ─────────────────────────────────┐
# │                                                                                                  │
# │  APT?      list pending updates → prompt → apt full-upgrade  → autoremove + clean                │
# │     ↓                                                                                            │
# │  DNF?      list pending updates → prompt → dnf upgrade       → autoremove + clean                │
# │     ↓                                                                                            │
# │  Flatpak?  list pending updates → prompt → flatpak update    → uninstall --unused                │
# │     ↓                                                                                            │
# │  Snap?     list pending updates → prompt → snap refresh                                          │
# │     ↓                                                                                            │
# │  Brew?     list pending updates → prompt → brew upgrade       → cleanup                          │
# │                                                                                                  │
# └──────────────────────────────────────────────────────────────────────────────────────────────────┘
#
# Usage:
#   upgrade            Interactive update (shows pending, prompts before each)
#   upgrade --check    List pending updates without installing anything

_has() { command -v "$1" >/dev/null 2>&1; }

CHECK_ONLY=false
for arg in "$@"; do
    case "$arg" in
        --check|-c) CHECK_ONLY=true ;;
        --help|-h)
            printf "Usage: upgrade [--check]\n\n"
            printf "  --check, -c   List pending updates without installing\n"
            exit 0 ;;
    esac
done

confirm() {
    printf "%s\n" "${1:-Are you sure you want to continue? Reply with [Y]es or [N]o and then press ENTER.}"
    while true; do
        read -r REPLY
        case "$REPLY" in
            [yY][eE][sS]|[yY]) return 0 ;;
            [nN][oO]|[nN])     return 1 ;;
            *) printf 'Please reply with either [Y]es or [N]o.\n' ;;
        esac
    done
}

found_updates=false

# ── APT ──────────────────────────────────────────────────────────────────────────
update_apt() {
    if ! _has apt-get; then return 1; fi

    printf "Checking for available APT updates...\n"
    sudo apt update -qq

    local updates
    updates=$(sudo apt-get -s dist-upgrade | awk '/^Inst/ { print $2 }')

    if [ -z "$updates" ]; then printf "No APT updates available.\n\n"; return 0; fi

    found_updates=true
    printf "%s\n\n" "$updates"
    if [[ "$CHECK_ONLY" == true ]]; then return 0; fi

    if ! confirm 'Start APT update? [y/N]'; then printf "APT update cancelled.\n\n"; return 0; fi

    sudo apt full-upgrade -y || { printf "APT upgrade failed.\n\n"; return 1; }

    printf "Doing APT clean-up...\n"
    sudo apt install -f -y
    sudo apt autoremove -y
    sudo apt clean

    printf "APT update finished.\n\n"
}

# ── DNF ──────────────────────────────────────────────────────────────────────────
update_dnf() {
    if ! _has dnf; then return 1; fi

    printf "Checking for available DNF updates...\n"

    # dnf check-update exits 100 if updates are available, 0 if none, 1 on error
    local updates rc
    updates=$(dnf check-update 2>/dev/null)
    rc=$?

    if [ "$rc" -eq 0 ]; then printf "No DNF updates available.\n\n"; return 0; fi
    if [ "$rc" -ne 100 ]; then printf "Error checking for DNF updates.\n\n"; return 1; fi

    found_updates=true
    printf "%s\n\n" "$updates"
    if [[ "$CHECK_ONLY" == true ]]; then return 0; fi

    if ! confirm 'Start DNF update? [y/N]'; then printf "DNF update cancelled.\n\n"; return 0; fi

    sudo dnf upgrade -y || { printf "DNF upgrade failed.\n\n"; return 1; }

    printf "Doing DNF clean-up...\n"
    sudo dnf autoremove -y
    sudo dnf clean all

    printf "DNF update finished.\n\n"
}

# ── Flatpak ──────────────────────────────────────────────────────────────────────
update_flatpaks() {
    if ! _has flatpak; then return 1; fi

    printf "Checking for available Flatpak updates...\n"

    local updates
    updates=$(flatpak remote-ls --updates 2>/dev/null)

    if [ -z "$updates" ]; then printf "No Flatpak updates available.\n\n"; return 0; fi

    found_updates=true
    printf "%s\n\n" "$updates"
    if [[ "$CHECK_ONLY" == true ]]; then return 0; fi

    if ! confirm 'Start Flatpak update? [y/N]'; then printf "Flatpak update cancelled.\n\n"; return 0; fi

    flatpak update -y || { printf "Flatpak update failed.\n\n"; return 1; }

    printf "Doing Flatpak clean-up...\n"
    flatpak uninstall --unused -y

    printf "Flatpak update finished.\n\n"
}

# ── Snap ─────────────────────────────────────────────────────────────────────────
update_snaps() {
    if ! _has snap; then return 1; fi

    printf "Checking for available Snap updates...\n"

    local updates
    if ! updates=$(sudo snap refresh --list 2>/dev/null) || [ -z "$updates" ]; then
        printf "No Snap updates available.\n\n"
        return 0
    fi

    found_updates=true
    printf "%s\n\n" "$updates"
    if [[ "$CHECK_ONLY" == true ]]; then return 0; fi

    if ! confirm 'Start Snap update? [y/N]'; then printf "Snap update cancelled.\n\n"; return 0; fi

    sudo snap refresh || { printf "Snap update failed.\n\n"; return 1; }

    printf "Snap update finished.\n\n"
}

# ── Homebrew ─────────────────────────────────────────────────────────────────────
update_brew() {
    if ! _has brew; then return 1; fi

    printf "Checking for available Homebrew updates...\n"
    brew update --quiet

    local outdated_formulae outdated_casks
    outdated_formulae=$(brew outdated --formula 2>/dev/null)
    outdated_casks=$(brew outdated --cask 2>/dev/null)

    if [ -z "$outdated_formulae" ] && [ -z "$outdated_casks" ]; then
        printf "No Homebrew updates available.\n\n"
        return 0
    fi

    found_updates=true
    if [ -n "$outdated_formulae" ]; then
        printf "Outdated formulae:\n%s\n\n" "$outdated_formulae"
    fi
    if [ -n "$outdated_casks" ]; then
        printf "Outdated casks:\n%s\n\n" "$outdated_casks"
    fi
    if [[ "$CHECK_ONLY" == true ]]; then return 0; fi

    if ! confirm 'Start Homebrew update? [y/N]'; then printf "Homebrew update cancelled.\n\n"; return 0; fi

    brew upgrade || { printf "Homebrew upgrade failed.\n\n"; return 1; }

    printf "Doing Homebrew clean-up...\n"
    brew cleanup

    printf "Homebrew update finished.\n\n"
}

# ── Main ─────────────────────────────────────────────────────────────────────────
if [[ "$CHECK_ONLY" == true ]]; then
    printf "\nChecking for pending updates...\n\n"
else
    printf "\nStarting system update...\n\n"
fi

if _has apt-get; then update_apt;      fi
if _has dnf;     then update_dnf;      fi
if _has flatpak; then update_flatpaks; fi
if _has snap;    then update_snaps;    fi
if _has brew;    then update_brew;     fi

if [[ "$CHECK_ONLY" == true ]]; then
    if [[ "$found_updates" == true ]]; then
        printf "Run 'upgrade' (without --check) to install.\n"
    else
        printf "Everything is up to date.\n"
    fi
else
    printf "Done. It's good practice to do a system reboot now.\n"
fi
