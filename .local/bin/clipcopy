#!/usr/bin/env bash
#
# clipcopy — Copy stdin or a file's contents to the system clipboard.
#
# Usage:
#   echo "hello" | clipcopy
#   clipcopy < myfile.txt
#   clipcopy myfile.txt

set -o errexit
set -o pipefail
set -o nounset

input="${1:-/dev/stdin}"

if [[ "$OSTYPE" == darwin* ]]; then
    pbcopy < "$input"
elif [[ -n "${WAYLAND_DISPLAY:-}" ]] && command -v wl-copy >/dev/null 2>&1; then
    wl-copy < "$input"
elif [[ -n "${DISPLAY:-}" ]] && command -v xclip >/dev/null 2>&1; then
    xclip -in -selection clipboard < "$input"
elif [[ -n "${DISPLAY:-}" ]] && command -v xsel >/dev/null 2>&1; then
    xsel --clipboard --input < "$input"
elif [[ -n "${TMUX:-}" ]] && command -v tmux >/dev/null 2>&1; then
    tmux load-buffer -
else
    printf 'clipcopy: no clipboard provider found.\n' >&2
    exit 1
fi
