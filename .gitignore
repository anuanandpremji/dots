# IDEs
/.vs/
/.vscode/
/.idea/

# Build/deps dir
/build/
/.deps/
/tmp/
/.clangd/
/.cache/clangd/
/.ccls-cache/

# OS
.DS_Store
*.mo
.*.sw?
*.pyc
*.o
*.so

# Sensitive / machine-specific files
.claude/settings.local.json
.config/git/config.default
.config/git/config.private
.config/git/config.work
.config/espanso/

# SSH keys (should never be committed)
**/*.pem
**/*.key
**/*.p12
**/id_rsa*
**/id_ed25519*
**/id_ecdsa*

# Zsh session restore files (auto-created by macOS)
.config/shell/zsh/.zsh_sessions/

# Backups and temp files
*.bak
*~
__pycache__/

